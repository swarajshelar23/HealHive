# ============================================
# HealHive Configuration (.env.example)
# ============================================
# Copy this file to .env and fill in actual values

# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# API Configuration
APP_BASE_URL=http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Anthropic AI Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# CrewAI Configuration (uses Anthropic by default)
CREWAI_MODEL=claude-3-5-sonnet-20241022

# JWT/Authentication Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production

# Redis Configuration (for real-time features)
REDIS_URL=redis://127.0.0.1:6379/1

# Database Configuration (optional - defaults to SQLite)
# URL format: postgresql://user:password@localhost:5432/healhive

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=noreply@healhive.com

# Frontend (Vite)
# Used by src/api/chatbot.js
VITE_API_URL=http://127.0.0.1:8000

# Logging Configuration (optional)
LOG_LEVEL=INFO
